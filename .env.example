# Saulzet & Vous — Variables d'environnement
# Copiez ce fichier en .env et adaptez les valeurs.

# --- Django ---
SECRET_KEY=changez-moi-en-production
DJANGO_SETTINGS_MODULE=saulzet_et_vous.settings.dev

# --- Réseau ---
ALLOWED_HOSTS=localhost,127.0.0.1,saulzet.jautzy.com
CSRF_TRUSTED_ORIGINS=https://saulzet.jautzy.com

# --- Base de données (production uniquement) ---
DATABASE_URL=postgres://user:password@localhost:5432/saulzet

# --- Email (production uniquement) ---
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=Saulzet & Vous <noreply@saulzet.jautzy.com>

# --- Site ---
SITE_URL=https://saulzet.jautzy.com
